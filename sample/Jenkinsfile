pipeline {
    agent any

    tools {
        // Automatically paths the designated Node.js version into the build environment
        nodejs 'NodeJS_20'
    }

    environment {
        DOCKER_IMAGE = "your-dockerhub-username/node-devops-app"
        IMAGE_TAG    = "${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS = 'docker-hub-credentials'
    }

    stages {
        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installing project dependencies cleanly...'
                sh 'npm ci'
            }
        }

        stage('Code Quality (Linting)') {
            steps {
                echo 'Checking code style with ESLint...'
                // sh 'npm run lint' 
                // Note: Using || true avoids breaking the pipeline immediately if you have minor lint errors during initial setups
                sh 'npm run lint || true' 
            }
        }

        stage('Security Vulnerability Scan') {
            steps {
                echo 'Auditing dependencies for known vulnerabilities...'
                // Checks for security flaws in your packages
                sh 'npm audit --audit-level=high || true'
            }
        }

        stage('Run Unit Tests') {
            steps {
                echo 'Executing Jest framework test suite...'
                sh 'npm test'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building production container image...'
                script {
                    dockerImage = docker.build("${DOCKER_IMAGE}:${IMAGE_TAG}")
                }
            }
        }

        stage('Push Image to Registry') {
            steps {
                echo 'Publishing built image to container registry...'
                script {
                    docker.withRegistry('https://index.docker.io/v1/', REGISTRY_CREDENTIALS) {
                        dockerImage.push()
                        dockerImage.push("latest") // Tagging it as the latest stable build
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Cleaning up the workspace...'
            cleanWs()
        }
        success {
            echo "Pipeline successfully compiled and published build #${BUILD_NUMBER}!"
        }
        failure {
            echo "Pipeline build failed. Review stage logs for details."
        }
    }
}